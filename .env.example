# ANTHROPIC_API_KEY: Påkrævet for al tekst- og analysegenerering (Claude API).
# Hentes på https://console.anthropic.com (forbrugs-faktureret — ikke det samme
# som et Claude Pro/Max-abonnement).
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Valgfrit: standardmodel til generering. Standard er Sonnet (balance kvalitet/pris).
# Sæt til "claude-opus-4-8" for højeste kvalitet (markant dyrere).
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Valgfrit: model til syntese-trinet i redaktionsmødet. Default Sonnet (hurtig +
# robust på Render). Sæt til "claude-opus-4-8" for mere kreativ forfinelse
# (langsommere, kræver at nøglen har Opus-adgang).
ANTHROPIC_CREATIVE_MODEL="claude-sonnet-4-6"

# Valgfrit: billig/hurtig model til triviel refinement (/api/refine).
ANTHROPIC_FAST_MODEL="claude-haiku-4-5"

# Valgfrit: max output-tokens for den store /generate-pakke.
ANTHROPIC_MAX_TOKENS="8000"

# Billed-udbyder: fal (standard, Flux 1.1 Pro) | openai | stability.
IMAGE_PROVIDER="fal"

# FAL_KEY: Påkrævet når IMAGE_PROVIDER=fal. Hentes på https://fal.ai/dashboard/keys
FAL_KEY="MY_FAL_KEY"

# APP_URL: Den URL hvor appen hostes (bruges til selv-refererende links).
APP_URL="MY_APP_URL"
